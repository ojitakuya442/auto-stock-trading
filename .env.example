# Discord Webhook URL（必須）
# 1. Discordサーバー → チャンネル設定 → 連携サービス → ウェブフック → 新しいウェブフック
# 2. URL をコピーして以下に設定
# 3. GitHub Actions では Secrets として登録 (DISCORD_WEBHOOK_URL)
DISCORD_WEBHOOK_URL=

# 動作モード（paper / live）。デフォルト paper
MODE=paper

# 仮想資産の初期額（円）
PAPER_INITIAL_CAPITAL=150000

# kabu Station API（Phase 2 以降で使用、現状は未使用）
KABU_API_TOKEN=
KABU_API_HOST=localhost
KABU_API_PORT=18080

# インサイダー対象銘柄（勤務先・関連企業）。カンマ区切りで指定。
# 例: INSIDER_BLACKLIST=7203.T,9984.T
# 注意: コミットしないこと。.env は .gitignore 済み
INSIDER_BLACKLIST=
